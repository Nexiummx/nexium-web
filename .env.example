# Copia este archivo como .env.local y llena los valores

# WhatsApp — solo dígitos (52 + lada + número). Acepta WA_NUMBER (recomendado en Vercel)
# o NEXT_PUBLIC_WA_NUMBER. Tras cambiar en Vercel: Redeploy.
WA_NUMBER=MX_WA_REDACTED

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=0000000000000000
